# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Apify (data scraping) ---
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
APIFY_OHLCV_ACTOR_ID=your-username~crypto-ohlcv-scraper
APIFY_BARS_LOOKBACK=1000

# --- Polymarket ---
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# --- Kalshi ---
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Kronos prediction model ---
# "local"  -> loads NeoQuasar/Kronos checkpoint via the kronos package (GPU optional, slow on CPU)
# "stub"   -> lightweight statistical momentum/volatility model, zero dependencies, runs anywhere
KRONOS_MODE=stub
KRONOS_MODEL_NAME=NeoQuasar/Kronos-small
KRONOS_LOOKBACK=512
KRONOS_HORIZON=5

# --- Risk management ---
KELLY_FRACTION_CAP=0.5
MAX_STAKE_PCT=0.05
BANKROLL_USD=1000
PAPER_TRADING=true

# --- Orchestration ---
POLL_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
ASSETS=BTC,ETH
